#!/usr/bin/env bash
set -euo pipefail

prog=${BASH_SOURCE[0]##*/}

# Resolve sibling schedule-network-task through any symlink install.
script_dir=$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")
# shellcheck source=schedule-network-task
source "$script_dir/schedule-network-task"

if [[ $# -gt 3 ]]; then
  echo "$prog: too many arguments — pass the prompt as a single quoted string" >&2
  echo "  example: $prog 4h30m \"Continue this work.\"" >&2
  exit 1
fi

if [[ $# -lt 2 ]]; then
  cat >&2 <<EOF
Usage: claude-resume-in <duration> [session-id] <prompt>

  duration:   compact format like 5d10h30m30s, 4h30m, 90m, 45s,
              or plain seconds (3600). Units must be in d→h→m→s order.
  session-id: optional UUID. If omitted, snapshots the most recent
              session in the current directory now and resumes that
              specific session at wake time (avoids being shadowed by
              a newer session started during the sleep window).
  prompt:     first message to send when the session resumes (required).

Examples:
  claude-resume-in 4h30m 948228a7-c941-4a6f-829a-86f8a5382a3e "Continue."
  claude-resume-in 4h30m "Continue."   # auto-resolve to most recent session

Notes:
  - Run in a terminal you'll leave open (or inside tmux/screen for safety).
  - System sleep is fine — the timer self-corrects against wall clock.
  - To start a fresh session instead of resuming, use \`claude-in\`.
EOF
  exit 1
fi

duration_str=$1
session_id=""
auto_resolved=0

# 2 args: $2 is the prompt, session is auto-resolved from cwd.
# 3 args: $2 must be a session UUID, $3 is the prompt.
uuid_re='^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$'
if [[ $# -ge 3 ]]; then
  if [[ ! $2 =~ $uuid_re ]]; then
    echo "$prog: '$2' isn't a session UUID" >&2
    exit 1
  fi
  session_id=$2
  prompt=$3
else
  if [[ $2 =~ $uuid_re ]]; then
    echo "$prog: prompt is required (got session-id but no prompt)" >&2
    exit 1
  fi
  prompt=$2
fi

# Validate duration before any side-effecting work below (e.g. session
# auto-resolution), so a bad duration surfaces as "invalid duration" rather
# than getting masked by "no prior session" in an empty cwd.
seconds=$(parse_duration "$duration_str")
if (( seconds <= 0 )); then
  echo "$prog: invalid duration: $duration_str" >&2
  exit 1
fi

# Eager --continue: snapshot the most-recent session now so a session started
# in this cwd during the sleep window can't shadow the one we meant to resume.
# Project dir encoding mirrors Claude Code: cwd with `/` and `.` → `-`.
if [[ -z $session_id ]]; then
  project_dir="$HOME/.claude/projects/${PWD//[\/.]/-}"
  # `|| true` keeps set -e + pipefail from aborting when the dir doesn't
  # exist or has no .jsonl files — we want to fall through to the friendly
  # error message below, not die silently.
  # shellcheck disable=SC2012  # filenames are UUIDs; ls -t is safe and shorter than the find equivalent
  latest=$(ls -t "$project_dir"/*.jsonl 2>/dev/null | head -1) || true
  [[ -n $latest ]] && session_id=$(basename "$latest" .jsonl)
  if [[ -z $session_id ]]; then
    echo "$prog: no prior session in $(pwd) to continue" >&2
    exit 1
  fi
  auto_resolved=1
fi

if (( auto_resolved )); then
  echo "Resuming most recent session (${session_id:0:8}…)"
else
  echo "Resuming session ${session_id:0:8}…"
fi
echo "Prompt: $prompt"

exec "$script_dir/schedule-network-task" "$seconds" api.anthropic.com:443 claude --resume "$session_id" -- "$prompt"
